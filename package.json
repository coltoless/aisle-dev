{
  "name": "aisle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "dev:nocache": "rm -rf .next && DISABLE_WEBPACK_CACHE=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "supabase": "supabase",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --schema public",
    "db:seed": "supabase db seed",
    "gen:types": "supabase gen types typescript --project-id tkpnrutloxtgabvnjsib > types/supabase.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
